# Copy this file to .env.local and fill in the values before running docker compose

# Database (matches docker-compose postgres service)
DATABASE_URL=postgres://blog:blogpassword@postgres:5432/blog_engine?sslmode=disable

# JWT — must be at least 32 characters
JWT_SECRET=change-me-at-least-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-at-least-32-chars!!

# SMTP — leave blank to disable email (server will log a warning but won't crash)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Google OAuth — leave blank to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Cloudflare R2 — leave as placeholder to disable image uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=blog-engine-images
R2_PUBLIC_URL=http://localhost:8080/uploads

# App
APP_URL=http://localhost:3000
PORT=8080
