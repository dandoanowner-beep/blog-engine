DATABASE_URL=postgres://user:password@localhost:5432/blog_engine?sslmode=disable
JWT_SECRET=replace-with-32-char-minimum-secret-key
JWT_REFRESH_SECRET=replace-with-different-32-char-secret
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=blog-engine-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev
APP_URL=http://localhost:3000
PORT=8080
